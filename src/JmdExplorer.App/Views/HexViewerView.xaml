<UserControl x:Class="JmdExplorer.App.Views.HexViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasFile, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="No file loaded." Foreground="{StaticResource TextDimBrush}" FontSize="15"/>
        </StackPanel>

        <Grid Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Hex Viewer" Style="{StaticResource HeaderText}"/>

            <!-- Toolbar -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                    <TextBlock Text="Go to:" VerticalAlignment="Center" Margin="0,0,6,0" Style="{StaticResource SubtleText}"/>
                    <TextBox Width="120" Text="{Binding GotoOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Go" Command="{Binding GotoCommand}" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                    <TextBlock Text="Hex:" VerticalAlignment="Center" Margin="0,0,6,0" Style="{StaticResource SubtleText}"/>
                    <TextBox Width="160" Text="{Binding SearchHexInput, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="e.g. 58 65 6E 6F 6E"/>
                    <Button Content="Find Hex" Command="{Binding SearchHexCommand}" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                    <TextBlock Text="Text:" VerticalAlignment="Center" Margin="0,0,6,0" Style="{StaticResource SubtleText}"/>
                    <TextBox Width="140" Text="{Binding SearchTextInput, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="e.g. Xenon"/>
                    <Button Content="Find Text" Command="{Binding SearchTextCommand}" Margin="6,0,0,0"/>
                </StackPanel>
            </WrapPanel>

            <!-- Hex grid -->
            <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource BgRaisedBrush}" Padding="14,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Offset" Width="100" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                            <TextBlock Text="00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F" Width="430"
                                       Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                            <TextBlock Text="ASCII" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Lines}" Margin="14,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding OffsetText}" Width="100"
                                                   Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                                        <TextBlock Text="{Binding HexText}" Width="430"
                                                   Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource MonoFont}"/>
                                        <TextBlock Text="{Binding AsciiText}"
                                                   Foreground="{StaticResource MonoAccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Footer: paging + copy + selection -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="◀ Prev" Command="{Binding PrevPageCommand}"/>
                    <Button Content="Next ▶" Command="{Binding NextPageCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Style="{StaticResource SubtleText}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Copy selection as:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource SubtleText}"/>
                    <Button Content="Hex" Command="{Binding CopyHexCommand}"/>
                    <Button Content="ASCII" Command="{Binding CopyAsciiCommand}"/>
                    <Button Content="C# bytes" Command="{Binding CopyCSharpCommand}"/>
                    <Button Content="Base64" Command="{Binding CopyBase64Command}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
