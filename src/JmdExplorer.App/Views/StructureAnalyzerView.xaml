<UserControl x:Class="JmdExplorer.App.Views.StructureAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Structure Analyzer" Style="{StaticResource HeaderText}"/>

        <!-- Action bar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="Analyze Structure" Style="{StaticResource AccentButton}"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding HasFile}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                <ProgressBar Width="200" Height="8" VerticalAlignment="Center" Margin="8,0,0,0"
                             Minimum="0" Maximum="100" Value="{Binding Progress}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource AccentBrush}" Background="{StaticResource BgPanelBrush}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="12,0,0,0"
                           Style="{StaticResource SubtleText}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Regions table -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Regions}" SelectedItem="{Binding SelectedRegion}"
                      Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Region" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Start" Binding="{Binding StartOffsetHex}" Width="Auto"/>
                    <DataGridTextColumn Header="End" Binding="{Binding EndOffsetHex}" Width="Auto"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding Size, StringFormat={}{0:N0} B}" Width="Auto"/>
                    <DataGridTextColumn Header="Entropy" Binding="{Binding Entropy, StringFormat=F2}" Width="Auto"/>
                    <DataGridTextColumn Header="% File" Binding="{Binding PercentOfFile, StringFormat=P1}" Width="Auto"/>
                    <DataGridTextColumn Header="Interpretation" Binding="{Binding SuggestedInterpretation}" Width="2*"/>
                    <DataGridTemplateColumn Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Hex" Padding="8,2" Margin="2"
                                        Command="{Binding DataContext.OpenInHexCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Right detail: repeating records -->
            <Border Grid.Column="1" Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Repeating Record Analysis" Style="{StaticResource HeaderText}" FontSize="15"/>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Candidate fixed-size record layouts (hypotheses, not confirmed structures)."/>
                    <ItemsControl ItemsSource="{Binding RecordPatterns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgRaisedBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding RecordSize, StringFormat=Record size: {0} bytes}" FontWeight="SemiBold"/>
                                            <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0" Background="{StaticResource AccentDimBrush}">
                                                <TextBlock Text="{Binding Confidence}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding EstimatedRecordCount, StringFormat=Estimated records: {0:N0}}" Style="{StaticResource SubtleText}" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding SimilarityRatio, StringFormat=Similarity: {0:P0}}" Style="{StaticResource SubtleText}"/>
                                        <TextBlock Text="{Binding Entropy, StringFormat=Entropy: {0:F2}}" Style="{StaticResource SubtleText}"/>
                                        <TextBlock Text="{Binding Interpretation}" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
