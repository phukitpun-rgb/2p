<UserControl x:Class="JmdExplorer.App.Views.FileInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasFile, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="56"
                       Foreground="{StaticResource AccentDimBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Drag a .jmd file here, or use Open File" Margin="0,16,0,0"
                       Foreground="{StaticResource TextDimBrush}" FontSize="15" HorizontalAlignment="Center"/>
            <TextBlock Text="JMD Explorer inspects binary structure honestly. It will not pretend to decode assets."
                       Margin="0,6,0,0" Foreground="{StaticResource TextDimBrush}" FontSize="12"
                       HorizontalAlignment="Center" MaxWidth="420" TextAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Loaded state -->
        <Grid Margin="24" Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- File metadata -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="File Information" Style="{StaticResource HeaderText}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="File Name" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileName}" Margin="0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Path" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FullPath}" Style="{StaticResource MonoText}"
                                   TextWrapping="Wrap" Margin="0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="File Size" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSize}" Margin="0,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="SHA-256" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Sha256}" Style="{StaticResource MonoText}"
                                   TextWrapping="Wrap" Margin="0,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Created" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CreatedDate}" Margin="0,6"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Modified" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ModifiedDate}" Margin="0,6"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Header Text" Style="{StaticResource SubtleText}" Margin="0,6"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding HeaderText}" Style="{StaticResource MonoText}"
                                   TextWrapping="Wrap" Margin="0,6"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Honesty / detection panel -->
            <Border Grid.Column="1" Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Detection &amp; Decode Status" Style="{StaticResource HeaderText}"/>

                    <TextBlock Text="Detected Format" Style="{StaticResource SubtleText}" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding DetectedFormat}" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border CornerRadius="4" Padding="8,3"
                                Background="{Binding ConfidenceColorKey, Converter={StaticResource KeyToBrush}}">
                            <TextBlock Text="{Binding Confidence}" Foreground="#FF14161B" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <TextBlock Text="confidence" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <Border Background="{StaticResource BgRaisedBrush}" CornerRadius="6" Padding="12" Margin="0,16,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding DetectedLine}" Style="{StaticResource MonoText}" Margin="0,2" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding StatusLine}" Foreground="{StaticResource WarnBrush}"
                                       FontFamily="{StaticResource MonoFont}" Margin="0,2" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding EmbeddedAssetsLine}" Style="{StaticResource MonoText}" Margin="0,2" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PayloadRegionLine}" Style="{StaticResource MonoText}" Margin="0,2" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ExtractionResultLine}" Style="{StaticResource MonoText}" Margin="0,2" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#332A1F1F" CornerRadius="6" Padding="12" Margin="0,16,0,0"
                            BorderBrush="{StaticResource WarnBrush}" BorderThickness="0,0,0,0">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource WarnBrush}" FontSize="12"
                                   Text="Note: recognizing a format is NOT the same as decoding it. Extracted payloads are raw binary and may be compressed, encrypted, or proprietary."/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
